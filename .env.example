# Copy this file to ``.env`` and fill in the keys you want to use.
# The sample at ``examples/sample.py`` (run via ``just run-sample``) loads
# whichever variable matches its ``--openai`` / ``--anthropic`` flag.

# OpenAI Chat Completions (default for ``just run-sample``).
OPENAI_API_KEY=

# Anthropic Messages API.
# An OAuth token (``sk-ant-oat...``) takes precedence if both are set.
ANTHROPIC_API_KEY=
# ANTHROPIC_OAUTH_TOKEN=
